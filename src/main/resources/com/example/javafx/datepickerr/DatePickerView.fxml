<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx.datepicker.DatePickerController">
   <children>
      <DatePicker fx:id="doDOB" layoutX="64.0" layoutY="43.0" prefHeight="32.0" prefWidth="193.0" />
      <Button layoutX="118.0" layoutY="121.0" mnemonicParsing="false" onAction="#doshow" prefHeight="32.0" prefWidth="85.0" text="show date" />
      <TextField fx:id="showdate" layoutX="86.0" layoutY="174.0" />
      <ImageView fx:id="imgid" fitHeight="118.0" fitWidth="174.0" layoutX="64.0" layoutY="247.0" pickOnBounds="true" preserveRatio="true" />
      <Button layoutX="359.0" layoutY="279.0" mnemonicParsing="false" onAction="#doselectpic" prefHeight="26.0" prefWidth="95.0" text="select image" />
      <Label fx:id="lblpath" layoutX="310.0" layoutY="328.0" prefHeight="18.0" prefWidth="271.0" text="Label" />
      <RadioButton fx:id="radcse" layoutX="384.0" layoutY="67.0" mnemonicParsing="false" text="CSE">
         <toggleGroup>
            <ToggleGroup fx:id="branch" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="radece" layoutX="385.0" layoutY="112.0" mnemonicParsing="false" text="ECE" toggleGroup="$branch" />
      <Button layoutX="385.0" layoutY="161.0" mnemonicParsing="false" onAction="#showbr" text="show branch" />
   </children>
</AnchorPane>
